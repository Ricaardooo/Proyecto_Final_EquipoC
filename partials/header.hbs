<header class="site-header">
  <div class="container header-content">
    <a class="brand" href="index.html" aria-label="Ir a la página de inicio">
      <img
        src="/img/logo.png"
        alt="Logo de Siscomp Technology"
        class="logo-img"
        width="120"
      />
      <span class="brand-text">
        <strong>Siscomp Technology</strong>
        <small>Tecnología y soporte técnico</small>
      </span>
    </a>

    <button
      class="menu-toggle"
      id="menuToggle"
      type="button"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mainNav"
    >
      ☰
    </button>

    <nav class="main-nav" id="mainNav" aria-label="Navegación principal">
      <a href="index.html" class="{{#if isHome}}active-link{{/if}}">Inicio</a>
      <a href="catalogo.html" class="{{#if isCatalog}}active-link{{/if}}">Catálogo</a>
      <a href="acerca.html" class="{{#if isAbout}}active-link{{/if}}">Acerca de Nosotros</a>
      <a href="galeria.html" class="{{#if isGallery}}active-link{{/if}}">Galería</a>
      <a href="soporte.html" class="{{#if isSupport}}active-link{{/if}}">Soporte</a>
      <a href="ofertas.html" class="{{#if isOffers}}active-link{{/if}}">Ofertas y Promociones</a>
      <a href="contacto.html" class="{{#if isContact}}active-link{{/if}}">Contáctenos</a>
      <a href="faq.html" class="{{#if isFAQ}}active-link{{/if}}">FAQ</a>
      <a href="login.html" class="btn-login {{#if isLogin}}active-link{{/if}}">Login</a>
      <a href="blog.html" class="{{#if isBlog}}active-link{{/if}}">Blog - Noticias</a>
    </nav>
  </div>
</header>