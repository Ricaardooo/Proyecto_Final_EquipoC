<header class="site-header">
  <div class="container header-content">
    <a class="brand" href="index.html" aria-label="Ir a la página de inicio">
      <img
        src="/img/logo.png"
        alt="Logo de Siscomp Technology"
        class="logo-img"
      />
      <span class="brand-text">
        <strong>Siscomp Technology</strong>
        <small>Tecnología y soporte técnico</small>
      </span>
    </a>

    <button
      class="menu-toggle"
      id="menuToggle"
      type="button"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
      aria-controls="mainNav"
    >
      ☰
    </button>

    <nav class="main-nav" id="mainNav" aria-label="Navegación principal">
      <a href="index.html" class="{{#if isHome}}active-link{{/if}}">Inicio</a>
      <a href="acerca.html" class="{{#if isAbout}}active-link{{/if}}">Acerca de Nosotros</a>
      <a href="login.html" class="{{#if isLogin}}active-link{{/if}}">Login</a>
    </nav>
  </div>
</header>