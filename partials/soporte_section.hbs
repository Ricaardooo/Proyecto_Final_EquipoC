<section class="support-hero">
  <div class="container support-hero__inner">
    <h1 class="support-hero__title">
      Soluciones técnicas <br />
      <span class="support-hero__accent">que puedes confiar</span>
    </h1>
    <p class="support-hero__subtitle">
      En Siscomp Technology te ofrecemos diagnóstico profesional, reparación
      garantizada y los mejores precios en equipos tecnológicos.
    </p>
    <div class="support-hero__actions">
      <a href="#solicitar-soporte" class="btn btn-primary">Solicitar soporte</a>
      <a href="#servicios" class="btn btn-outline">Ver servicios</a>
    </div>
  </div>
</section>

<section class="support-services" id="servicios">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Nuestros Servicios</h2>
      <p class="section-subtitle">
        Atendemos tu equipo con rapidez, honestidad y experiencia comprobada.
      </p>
    </div>

    <div class="support-services__grid">

      <article class="service-card">
        <img class="service-card__img" src="/img/DIAGNOSTICO.jpg" alt="Diagnóstico Técnico">
        <div class="service-card__body">
          <h3 class="service-card__title">Diagnóstico Técnico</h3>
          <p class="service-card__desc">
            Evaluamos tu computadora o laptop con herramientas especializadas para
            identificar fallas de hardware y software de forma precisa y rápida.
          </p>
        </div>
      </article>

      <article class="service-card service-card--featured">
        <img class="service-card__img" src="/img/reparacion.jpg" alt="Reparación de Equipos">
        <div class="service-card__body">
          <h3 class="service-card__title">Reparación de Equipos</h3>
          <p class="service-card__desc">
            Reparamos computadoras de escritorio y laptops de todas las marcas.
            Usamos repuestos de calidad y entregamos tu equipo funcionando al 100%.
          </p>
        </div>
      </article>

      <article class="service-card">
        <img class="service-card__img" src="/img/tienda.png" alt="Venta de Productos">
        <div class="service-card__body">
          <h3 class="service-card__title">Venta de Productos</h3>
          <p class="service-card__desc">
            Contamos con un amplio catálogo de equipos y accesorios tecnológicos
            a los mejores precios del mercado, con garantía incluida.
          </p>
        </div>
      </article>

  </div>

    </div>
  </div>
</section>

<section class="support-warranty" id="garantias">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Información sobre Garantías</h2><br>
      <p class="section-subtitle">
        Respaldamos nuestro trabajo y los productos que vendemos.
      </p>
    </div>

    <div class="row">

      <div class="col-3">
        <div class="warranty-card">
          <div class="warranty-card__icon"></div>
          <h3 class="warranty-card__title">Garantía de Reparación</h3>
          <p class="warranty-card__desc">
            Toda reparación realizada en nuestro taller tiene
            <strong>30 días de garantía</strong> sobre el trabajo efectuado.
            Si el mismo problema regresa, lo solucionamos sin costo adicional.
          </p>
        </div>
      </div>

      <div class="col-3">
        <div class="warranty-card">
          <div class="warranty-card__icon"></div>
          <h3 class="warranty-card__title">Garantía de Productos</h3>
          <p class="warranty-card__desc">
            Los equipos y accesorios que vendemos incluyen
            <strong>garantía del fabricante</strong>. Te asesoramos en el proceso
            de reclamación sin ningún costo extra.
          </p>
        </div>
      </div>

      <div class="col-3">
        <div class="warranty-card">
          <div class="warranty-card__icon"></div>
          <h3 class="warranty-card__title">Condiciones Generales</h3>
          <p class="warranty-card__desc">
            La garantía aplica bajo uso normal del equipo y no cubre daños por
            líquidos, golpes externos o manipulación no autorizada.
          </p>
        </div>
      </div>

      <div class="col-3">
        <div class="warranty-card">
          <div class="warranty-card__icon"></div>
          <h3 class="warranty-card__title">Servicio Prioritario</h3>
          <p class="warranty-card__desc">
            Los clientes con garantía activa tienen atención prioritaria en
            tienda. Trae tu comprobante de servicio o factura de compra.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<section class="support-form-section" id="solicitar-soporte">
  <div class="container">
    <div class="row">

      <div class="col-5 support-form-section__info">
        <span class="section-tag">Estamos aquí</span>
        <h2 class="section-title">Solicitar Soporte Técnico</h2><br>
        <p>
          Completa el formulario y uno de nuestros técnicos se pondrá en
          contacto contigo a la brevedad para coordinar la revisión de tu equipo.
        </p>
        <ul class="support-contact-list">
          <li> <span>+504 3290-7034</span></li>
          <li> <span>soporte@siscomp.com</span></li>
          <li> <span>Lun – Sáb, 9:00 am – 5:30 pm</span></li>
        </ul>
      </div>

      <div class="col-7">
        <form class="support-form" id="soporteForm" novalidate>

          <div class="row">
            <div class="col-6">
              <div class="form-group">
                <label for="sf-nombre" class="form-label">Nombre completo *</label>
                <input type="text" id="sf-nombre" name="nombre" class="form-input"
                  placeholder="Tu nombre" required autocomplete="name" />
                <span class="form-error" id="sf-nombre-error"></span>
              </div>
            </div>
            <div class="col-6">
              <div class="form-group">
                <label for="sf-email" class="form-label">Correo electrónico *</label>
                <input type="email" id="sf-email" name="email" class="form-input"
                  placeholder="correo@ejemplo.com" required autocomplete="email" />
                <span class="form-error" id="sf-email-error"></span>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-6">
              <div class="form-group">
                <label for="sf-telefono" class="form-label">Teléfono</label>
                <input type="tel" id="sf-telefono" name="telefono" class="form-input"
                  placeholder="+504 0000-0000" autocomplete="tel" />
              </div>
            </div>
            <div class="col-6">
              <div class="form-group">
                <label for="sf-servicio" class="form-label">Tipo de servicio *</label>
                <select id="sf-servicio" name="servicio" class="form-input" required>
                  <option value="" disabled selected>Selecciona un servicio</option>
                  <option value="diagnostico">Diagnóstico técnico</option>
                  <option value="reparacion">Reparación de equipo</option>
                  <option value="venta">Consulta de producto / venta</option>
                  <option value="garantia">Garantía</option>
                  <option value="otro">Otro</option>
                </select>
                <span class="form-error" id="sf-servicio-error"></span>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="form-group">
                <label for="sf-equipo" class="form-label">Tipo de equipo</label>
                <input type="text" id="sf-equipo" name="equipo" class="form-input"
                  placeholder="Ej: Laptop HP, PC de escritorio Dell…" />
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <div class="form-group">
                <label for="sf-descripcion" class="form-label">Descripción del problema *</label>
                <br><br><textarea id="sf-descripcion" name="descripcion" class="form-input form-textarea"
                  placeholder="Describe brevemente el problema o lo que necesitas…"
                  rows="5" required></textarea>
                <span class="form-error" id="sf-descripcion-error"></span>
              </div>
            </div>
          </div>

          <div class="row">
            <div class="col-12">
              <button type="submit" class="btn btn-primary btn-full">
                Enviar solicitud
              </button>
              <p class="form-note">* Campos obligatorios. Nos comunicaremos contigo en un plazo máximo de 24 horas.</p>
            </div>
          </div>

        </form>
      </div>

    </div>
  </div>
</section>